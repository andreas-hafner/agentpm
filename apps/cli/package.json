{
  "name": "agentpm",
  "version": "0.2.2",
  "license": "MIT",
  "description": "Project-aware AI skill orchestration CLI",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "agentpm": "./bin/agentpm.js"
  },
  "files": [
    "bin",
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node24 --clean",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agentpm/core": "workspace:*",
    "@agentpm/ui": "workspace:*",
    "commander": "^14.0.0"
  }
}
